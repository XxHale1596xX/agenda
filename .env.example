# Copie para .env e preencha os valores reais. NUNCA commite o .env.

# ── Banco de dados ────────────────────────────────────────────────────────────
DATABASE_URL=mysql+pymysql://agenda:TROQUE_AQUI@mysql:3306/agenda

# ── Admin ─────────────────────────────────────────────────────────────────────
# Dev: use ADMIN_TOKEN com texto puro
ADMIN_TOKEN=troque-por-uma-senha-forte

# Produção: gere o hash e use ADMIN_TOKEN_HASH (ADMIN_TOKEN_HASH tem precedência)
# Para gerar: python3 -c "from passlib.context import CryptContext; print(CryptContext(['bcrypt']).hash('sua-senha'))"
ADMIN_TOKEN_HASH=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Lista separada por vírgula dos domínios permitidos
ALLOWED_ORIGINS=http://localhost:5173

# ── JWT (portal do aluno) ─────────────────────────────────────────────────────
# Gere com: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=troque-por-chave-aleatoria-forte

# ── Log ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
